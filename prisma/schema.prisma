generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String    // bcrypt hash
  role      String    @default("member")
  createdAt DateTime  @default(now())
  donations Donation[]
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  location    String
  startTime   DateTime
  endTime     DateTime?
  createdAt   DateTime @default(now())
}

model Sermon {
  id          String   @id @default(cuid())
  title       String
  speaker     String
  series      String?
  date        DateTime
  videoUrl    String?
  audioUrl    String?
  summary     String
  createdAt   DateTime @default(now())
}

model Donation {
  id          String   @id @default(cuid())
  amountCents Int
  fund        String   // e.g. "General", "Missions", "Building"
  donorName   String?
  donorEmail  String?
  memberId    String?
  member      Member?  @relation(fields: [memberId], references: [id])
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  reason    String?
  message   String
  createdAt DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  excerpt     String?
  content     String
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  createdAt   DateTime @default(now())
}

model MembershipRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  message     String?
  status      String   @default("new")
  createdAt   DateTime @default(now())
}
